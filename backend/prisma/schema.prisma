generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admin_users {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique @db.VarChar(255)
  password_hash      String
  full_name          String    @db.VarChar(255)
  phone              String?   @db.VarChar(20)
  profile_image      String?
  is_verified        Boolean?  @default(false)
  verification_token String?
  reset_token        String?
  reset_token_expiry DateTime? @db.Timestamptz(6)
  last_login         DateTime? @db.Timestamptz(6)
  is_active          Boolean?  @default(true)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  clinics            clinics[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointment_slots {
  id           String         @id @default(uuid()) @db.Uuid
  doctor_id    String         @db.Uuid
  clinic_id    String         @db.Uuid
  slot_date    DateTime       @db.Date
  start_time   DateTime       @db.Time(6)
  end_time     DateTime       @db.Time(6)
  is_booked    Boolean?       @default(false)
  is_blocked   Boolean?       @default(false)
  block_reason String?        @db.VarChar(255)
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  clinics      clinics        @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctors      doctors        @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointments appointments[]

  @@unique([doctor_id, slot_date, start_time])
  @@index([doctor_id, slot_date], map: "idx_appointment_slots_doctor_date")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointments {
  id                  String             @id @default(uuid()) @db.Uuid
  clinic_id           String             @db.Uuid
  doctor_id           String             @db.Uuid
  slot_id             String?            @db.Uuid
  patient_name        String             @db.VarChar(255)
  patient_email       String             @db.VarChar(255)
  patient_phone       String             @db.VarChar(20)
  patient_age         Int?
  patient_gender      String?            @db.VarChar(20)
  patient_address     String?
  appointment_date    DateTime           @db.Date
  appointment_time    DateTime           @db.Time(6)
  reason_for_visit    String?
  symptoms            String?
  status              String?            @default("pending") @db.VarChar(50)
  cancellation_reason String?
  admin_notes         String?
  prescription_url    String?
  booking_reference   String             @unique @db.VarChar(20)
  confirmed_at        DateTime?          @db.Timestamptz(6)
  cancelled_at        DateTime?          @db.Timestamptz(6)
  completed_at        DateTime?          @db.Timestamptz(6)
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?          @default(now()) @db.Timestamptz(6)
  clinics             clinics            @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctors             doctors            @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointment_slots   appointment_slots? @relation(fields: [slot_id], references: [id], onUpdate: NoAction)

  @@index([clinic_id], map: "idx_appointments_clinic_id")
  @@index([appointment_date], map: "idx_appointments_date")
  @@index([doctor_id], map: "idx_appointments_doctor_id")
  @@index([status], map: "idx_appointments_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model blog_posts {
  id               String    @id @default(uuid()) @db.Uuid
  clinic_id        String    @db.Uuid
  title            String    @db.VarChar(500)
  slug             String    @db.VarChar(500)
  excerpt          String?
  content          String
  cover_image      String?
  tags             String[]
  category         String?   @db.VarChar(100)
  status           String?   @default("draft") @db.VarChar(20)
  author_name      String?   @db.VarChar(255)
  meta_title       String?   @db.VarChar(255)
  meta_description String?
  views            Int?      @default(0)
  published_at     DateTime? @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  clinics          clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([clinic_id, slug])
  @@index([clinic_id, status], map: "idx_blog_posts_clinic")
}

model clinic_certifications {
  id                 String    @id @default(uuid()) @db.Uuid
  clinic_id          String    @db.Uuid
  title              String    @db.VarChar(255)
  issuing_authority  String    @db.VarChar(255)
  certificate_number String?   @db.VarChar(100)
  issued_date        DateTime? @db.Date
  expiry_date        DateTime? @db.Date
  certificate_url    String?
  is_verified        Boolean?  @default(false)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  clinics            clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model clinic_facilities {
  id          String      @id @default(uuid()) @db.Uuid
  clinic_id   String      @db.Uuid
  facility_id String?     @db.Uuid
  custom_name String?     @db.VarChar(100)
  custom_icon String?     @db.VarChar(50)
  description String?
  created_at  DateTime?   @default(now()) @db.Timestamptz(6)
  clinics     clinics     @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  facilities  facilities? @relation(fields: [facility_id], references: [id], onUpdate: NoAction)
}

model clinic_themes {
  id               String    @id @default(uuid()) @db.Uuid
  clinic_id        String    @unique @db.Uuid
  template_id      String?   @default("modern") @db.VarChar(50)
  primary_color    String?   @default("#2563EB") @db.VarChar(7)
  secondary_color  String?   @default("#10B981") @db.VarChar(7)
  accent_color     String?   @default("#F59E0B") @db.VarChar(7)
  background_color String?   @default("#FFFFFF") @db.VarChar(7)
  text_color       String?   @default("#1F2937") @db.VarChar(7)
  font_family      String?   @default("Inter") @db.VarChar(100)
  heading_font     String?   @default("Poppins") @db.VarChar(100)
  border_radius    String?   @default("8px") @db.VarChar(20)
  custom_css       String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  clinics          clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model clinic_working_hours {
  id          String    @id @default(uuid()) @db.Uuid
  clinic_id   String    @db.Uuid
  day_of_week Int
  is_open     Boolean?  @default(true)
  open_time   DateTime? @db.Time(6)
  close_time  DateTime? @db.Time(6)
  has_break   Boolean?  @default(false)
  break_start DateTime? @db.Time(6)
  break_end   DateTime? @db.Time(6)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  clinics     clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([clinic_id, day_of_week])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model clinics {
  id                    String                  @id @default(uuid()) @db.Uuid
  admin_id              String                  @db.Uuid
  clinic_id_slug        String                  @unique @db.VarChar(100)
  clinic_name           String                  @db.VarChar(255)
  tagline               String?                 @db.VarChar(500)
  description           String?
  phone                 String                  @db.VarChar(20)
  email                 String                  @db.VarChar(255)
  website               String?                 @db.VarChar(255)
  whatsapp              String?                 @db.VarChar(20)
  address_line1         String                  @db.VarChar(255)
  address_line2         String?                 @db.VarChar(255)
  city                  String                  @db.VarChar(100)
  state                 String                  @db.VarChar(100)
  pincode               String                  @db.VarChar(20)
  country               String?                 @default("India") @db.VarChar(100)
  google_maps_link      String?
  latitude              Decimal?                @db.Decimal(10, 8)
  longitude             Decimal?                @db.Decimal(11, 8)
  about_us              String?
  mission               String?
  vision                String?
  established_year      Int?
  registration_number   String?                 @db.VarChar(100)
  gstin                 String?                 @db.VarChar(20)
  logo_url              String?
  banner_url            String?
  gallery_urls          String[]
  is_published          Boolean?                @default(false)
  is_active             Boolean?                @default(true)
  published_at          DateTime?               @db.Timestamptz(6)
  total_patients        Int?                    @default(0)
  total_doctors         Int?                    @default(0)
  rating                Decimal?                @default(0) @db.Decimal(3, 2)
  review_count          Int?                    @default(0)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  appointment_slots     appointment_slots[]
  appointments          appointments[]
  blog_posts            blog_posts[]
  clinic_certifications clinic_certifications[]
  clinic_facilities     clinic_facilities[]
  clinic_themes         clinic_themes?
  clinic_working_hours  clinic_working_hours[]
  admin_users           admin_users             @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctor_schedules      doctor_schedules[]
  doctors               doctors[]
  service_categories    service_categories[]
  services              services[]

  @@index([admin_id], map: "idx_clinics_admin_id")
  @@index([is_published], map: "idx_clinics_published")
  @@index([clinic_id_slug], map: "idx_clinics_slug")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model doctor_schedules {
  id               String    @id @default(uuid()) @db.Uuid
  doctor_id        String    @db.Uuid
  clinic_id        String    @db.Uuid
  day_of_week      Int
  is_available     Boolean?  @default(true)
  start_time       DateTime  @db.Time(6)
  end_time         DateTime  @db.Time(6)
  slot_duration    Int?      @default(20)
  max_appointments Int?      @default(20)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  clinics          clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  doctors          doctors   @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([doctor_id, day_of_week])
  @@index([doctor_id], map: "idx_doctor_schedules_doctor")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model doctors {
  id                          String              @id @default(uuid()) @db.Uuid
  clinic_id                   String              @db.Uuid
  full_name                   String              @db.VarChar(255)
  profile_image               String?
  gender                      String?             @db.VarChar(20)
  date_of_birth               DateTime?           @db.Date
  qualification               String              @db.VarChar(500)
  specialization              String              @db.VarChar(255)
  sub_specialization          String?             @db.VarChar(255)
  experience_years            Int
  designation                 String?             @db.VarChar(255)
  department                  String?             @db.VarChar(255)
  medical_registration_number String?             @unique @db.VarChar(100)
  registration_council        String?             @db.VarChar(255)
  registration_valid_till     DateTime?           @db.Date
  email                       String?             @db.VarChar(255)
  phone                       String?             @db.VarChar(20)
  bio                         String?
  achievements                String[]
  languages_spoken            String[]
  consultation_fee            Decimal?            @db.Decimal(10, 2)
  online_consultation_fee     Decimal?            @db.Decimal(10, 2)
  consultation_duration       Int?                @default(20)
  is_active                   Boolean?            @default(true)
  is_featured                 Boolean?            @default(false)
  sort_order                  Int?                @default(0)
  created_at                  DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?           @default(now()) @db.Timestamptz(6)
  appointment_slots           appointment_slots[]
  appointments                appointments[]
  doctor_schedules            doctor_schedules[]
  clinics                     clinics             @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clinic_id], map: "idx_doctors_clinic_id")
}

model facilities {
  id                String              @id @default(uuid()) @db.Uuid
  name              String              @db.VarChar(100)
  icon              String?             @db.VarChar(50)
  description       String?             @db.VarChar(255)
  is_default        Boolean?            @default(true)
  clinic_facilities clinic_facilities[]
}

model platform_admins {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String
  full_name     String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model service_categories {
  id          String     @id @default(uuid()) @db.Uuid
  clinic_id   String     @db.Uuid
  name        String     @db.VarChar(100)
  icon        String?    @db.VarChar(50)
  description String?
  sort_order  Int?       @default(0)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  clinics     clinics    @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services    services[]
}

model services {
  id                 String              @id @default(uuid()) @db.Uuid
  clinic_id          String              @db.Uuid
  category_id        String?             @db.Uuid
  name               String              @db.VarChar(255)
  description        String?
  duration_minutes   Int?                @default(30)
  price_min          Decimal?            @db.Decimal(10, 2)
  price_max          Decimal?            @db.Decimal(10, 2)
  price_display      String?             @db.VarChar(100)
  image_url          String?
  is_active          Boolean?            @default(true)
  is_featured        Boolean?            @default(false)
  sort_order         Int?                @default(0)
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?           @default(now()) @db.Timestamptz(6)
  service_categories service_categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  clinics            clinics             @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clinic_id], map: "idx_services_clinic_id")
}

model Patient {
  id        String   @id @default(uuid())
  phone     String   @unique
  email     String?
  full_name String?

  date_of_birth DateTime?
  gender        String?
  blood_group   String?

  address String?

  emergency_contact_name  String?
  emergency_contact_phone String?

  allergies          String?
  chronic_conditions String?

  is_active  Boolean  @default(true)
  last_login DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  appointments Appointment[]

  @@index([phone])
}


model PatientOtp {
  id         String   @id @default(uuid())
  phone      String
  otp_code   String
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([phone])
}


model Appointment {
  id         String   @id @default(uuid())
  patient_id String?

  patient Patient? @relation(fields: [patient_id], references: [id], onDelete: SetNull)
}